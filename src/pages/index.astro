---
import Base from '../layouts/Base.astro';
---
<Base title="MatCraft — Building…" description="Premium mousemats — site under construction.">
  <main class="min-h-screen flex items-center justify-center p-8">
    <div class="max-w-2xl text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[color:var(--color-accent)] pulse-ring mb-8"></div>
      <h1 class="text-5xl md:text-7xl font-semibold tracking-tight">MatCraft</h1>
      <p class="mt-4 text-lg text-[color:var(--color-muted)]">🛠  Building the MatCraft store — crafting every surface, stitching every edge…</p>
      <p class="mt-10 text-sm uppercase tracking-widest text-[color:var(--color-muted)]">Precision surfaces · coming online</p>
    </div>
  </main>
</Base>
