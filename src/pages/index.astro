---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import { getProducts, formatPrice } from '../lib/supabase';
import { organizationSchema, websiteSchema } from '../lib/schema';

const products = await getProducts();
const featured = products.filter(p => p.is_featured).slice(0, 6);
const collections = [
  { slug: 'gaming', name: 'Gaming', blurb: 'Speed and control weaves tuned for high-DPI mice.', img: 'https://images.unsplash.com/photo-1593305841991-05c297ba4575?w=900&auto=format&fit=crop' },
  { slug: 'extended', name: 'Extended', blurb: 'Full-desk coverage for keyboard and mouse in one surface.', img: 'https://images.unsplash.com/photo-1629429407759-01cd3d7cfb38?w=900&auto=format&fit=crop' },
  { slug: 'custom', name: 'Custom', blurb: 'Upload artwork. We stitch it into a mat.', img: 'https://images.unsplash.com/photo-1587202372775-e229f172b9d7?w=900&auto=format&fit=crop' },
  { slug: 'rgb', name: 'RGB', blurb: '14-mode LED borders for battlestations.', img: 'https://images.unsplash.com/photo-1600267165477-6d4cc8b7cfe7?w=900&auto=format&fit=crop' },
];
---
<Base
  title="Mousemats | MatCraft"
  description="Shop MatCraft's full range of premium mousemats. Gaming, desk, extended, and custom designs. Free shipping on orders over £30. Find your perfect surface today."
  structuredData={[organizationSchema(), websiteSchema()]}
>
<Header />

<main>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="container-x pt-20 pb-16 md:pt-28 md:pb-24 grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-7">
        <span class="inline-flex items-center gap-2 text-xs uppercase tracking-widest text-[color:var(--color-muted)] mb-5">
          <span class="w-2 h-2 rounded-full bg-[color:var(--color-accent)] pulse-ring"></span>
          Free UK shipping over £30
        </span>
        <h1 class="text-5xl md:text-7xl font-semibold tracking-tight leading-[0.95]">Premium mousemats<br/>for every setup.</h1>
        <p class="mt-6 text-lg md:text-xl text-[color:var(--color-muted)] max-w-xl">Precision-stitched surfaces engineered for gamers, designers and professionals. From compact travel mats to 1.2m full-desk pads — built to last, tuned to track.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/shop" class="btn btn-primary">Shop all mousemats</a>
          <a href="/collections/gaming" class="btn btn-ghost">Explore gaming range</a>
        </div>
        <div class="mt-10 flex items-center gap-6 text-sm text-[color:var(--color-muted)]">
          <div class="flex items-center gap-2"><span class="text-[color:var(--color-ink)] font-semibold">4.9★</span> · 1,800+ reviews</div>
          <div class="hidden sm:block">·</div>
          <div class="hidden sm:block">Stitched edges · Anti-slip base</div>
        </div>
      </div>
      <div class="md:col-span-5 relative">
        <div class="card p-3 rotate-1 shadow-xl">
          <img src="https://images.unsplash.com/photo-1587202372775-e229f172b9d7?w=900&auto=format&fit=crop" alt="MatCraft premium gaming mousemat on a walnut desk with keyboard and mouse" class="rounded-2xl w-full object-cover aspect-[4/5]" />
        </div>
        <div class="card absolute -bottom-6 -left-6 p-4 max-w-[220px] -rotate-3 hidden md:block">
          <div class="text-xs font-semibold uppercase tracking-wide text-[color:var(--color-accent)]">Bestseller</div>
          <div class="mt-1 font-semibold">MatCraft Speed</div>
          <div class="text-sm text-[color:var(--color-muted)]">Ultra-fast glide · stitched edges</div>
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <section class="border-y border-[color:var(--color-line)] bg-white/40">
    <div class="container-x py-5 flex items-center gap-10 overflow-x-auto text-sm text-[color:var(--color-muted)] whitespace-nowrap">
      <span>★ Stitched edges</span>
      <span>· Natural rubber base</span>
      <span>· Micro-fibre top layer</span>
      <span>· Free UK shipping over £30</span>
      <span>· 30-day returns</span>
      <span>· Made in the UK</span>
      <span>· Over 180,000 desks upgraded</span>
    </div>
  </section>

  <!-- COLLECTIONS -->
  <section class="container-x py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-3xl md:text-5xl font-semibold tracking-tight">Shop by collection</h2>
        <p class="mt-3 text-[color:var(--color-muted)] max-w-xl">Pick the surface that matches your setup. Every MatCraft mousemat ships with stitched edges, a non-slip base, and our 30-day try-it-out promise.</p>
      </div>
      <a href="/collections" class="hidden md:inline btn btn-ghost text-sm">All collections →</a>
    </div>
    <div class="grid md:grid-cols-4 gap-5">
      {collections.map(c => (
        <a href={`/collections/${c.slug}`} class="group card overflow-hidden hover:-translate-y-1 transition">
          <div class="aspect-[4/5] overflow-hidden">
            <img src={c.img} alt={`${c.name} mousemat collection`} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
          </div>
          <div class="p-5">
            <h3 class="font-semibold text-lg">{c.name}</h3>
            <p class="mt-1 text-sm text-[color:var(--color-muted)]">{c.blurb}</p>
            <span class="mt-3 inline-flex text-sm font-medium group-hover:text-[color:var(--color-accent)]">Shop {c.name} →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="container-x pb-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-3xl md:text-5xl font-semibold tracking-tight">Bestselling mousemats</h2>
        <p class="mt-3 text-[color:var(--color-muted)] max-w-xl">The surfaces our customers keep coming back to.</p>
      </div>
      <a href="/shop" class="btn btn-ghost text-sm">View all →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {featured.map(p => <ProductCard p={p} />)}
    </div>
  </section>

  <!-- CRAFT STORY -->
  <section class="container-x pb-20">
    <div class="card relative overflow-hidden grain p-10 md:p-16 bg-gradient-to-br from-[color:var(--color-bone)] to-white">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <span class="text-xs uppercase tracking-widest text-[color:var(--color-accent)] font-semibold">The MatCraft difference</span>
          <h2 class="mt-3 text-3xl md:text-5xl font-semibold tracking-tight">Five layers. One perfect surface.</h2>
          <p class="mt-5 text-[color:var(--color-muted)] text-lg">Every MatCraft mat is built up from five engineered layers — protective weave, glide coat, cushion core, anti-slip rubber, and double-stitched edges — to give your mouse a consistent, silent, long-lasting home.</p>
          <ul class="mt-6 space-y-3 text-sm">
            <li class="flex gap-3"><span class="text-[color:var(--color-accent)] font-semibold">01</span> Micro-fibre weave treated for low friction</li>
            <li class="flex gap-3"><span class="text-[color:var(--color-accent)] font-semibold">02</span> Closed-cell foam core for consistent feel</li>
            <li class="flex gap-3"><span class="text-[color:var(--color-accent)] font-semibold">03</span> Natural rubber base that locks onto any desk</li>
            <li class="flex gap-3"><span class="text-[color:var(--color-accent)] font-semibold">04</span> Double stitching that never frays</li>
          </ul>
          <a href="/about" class="mt-8 inline-flex btn btn-primary">Learn our craft →</a>
        </div>
        <div class="relative">
          <img src="https://images.unsplash.com/photo-1629429408209-1f912961dbd8?w=1200&auto=format&fit=crop" alt="Close-up of MatCraft stitched mousemat edge showing cloth weave" class="rounded-3xl w-full object-cover aspect-square" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ TEASER -->
  <section class="container-x pb-24">
    <div class="grid md:grid-cols-2 gap-10">
      <div>
        <h2 class="text-3xl md:text-5xl font-semibold tracking-tight">Common questions</h2>
        <p class="mt-3 text-[color:var(--color-muted)] max-w-md">More in our <a href="/faq" class="underline">full FAQ</a> — or <a href="/contact" class="underline">get in touch</a> if you need personalised advice.</p>
      </div>
      <div class="space-y-4">
        {[
          { q: 'Which mousemat is best for gaming?', a: 'If you play at low DPI, go XL Speed. For FPS precision, pick our Control weave.' },
          { q: 'Do you ship outside the UK?', a: 'Yes — we ship worldwide from our Manchester workshop, typically in 3-7 working days.' },
          { q: 'Can I return a mousemat?', a: 'Absolutely — 30 days, no questions asked. Custom prints are the only exception.' },
        ].map(f => (
          <details class="card p-5 group">
            <summary class="font-medium cursor-pointer flex justify-between items-center">
              {f.q}
              <span class="text-[color:var(--color-muted)] group-open:rotate-45 transition">+</span>
            </summary>
            <p class="mt-3 text-sm text-[color:var(--color-muted)]">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</main>

<Footer />
</Base>
