---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<Base title="Order confirmed | MatCraft" description="Thanks for your order — your MatCraft mousemat is on its way." noindex={true}>
<Header />
<main class="container-x py-20 text-center">
  <div class="mx-auto max-w-xl">
    <div class="mx-auto w-16 h-16 rounded-full bg-[color:var(--color-accent)]/15 text-[color:var(--color-accent)] flex items-center justify-center text-3xl">✓</div>
    <h1 class="mt-6 text-4xl md:text-5xl font-semibold tracking-tight">Order confirmed</h1>
    <p class="mt-4 text-lg text-[color:var(--color-muted)]">Thanks for choosing MatCraft. We've emailed your receipt and started prepping your mousemat for dispatch. You'll get a tracking link as soon as it leaves the workshop.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/shop" class="btn btn-primary">Keep shopping</a>
      <a href="/" class="btn btn-ghost">Back to home</a>
    </div>
  </div>
</main>
<Footer />
<script is:inline>
  try { localStorage.removeItem('matcraft_cart'); window.dispatchEvent(new Event('matcraft:cart')); } catch {}
</script>
</Base>
