---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<Base title="Order cancelled | MatCraft" description="Your checkout was cancelled. Your cart is still saved." noindex={true}>
<Header />
<main class="container-x py-20 text-center">
  <div class="mx-auto max-w-xl">
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight">Checkout cancelled</h1>
    <p class="mt-4 text-lg text-[color:var(--color-muted)]">No worries — your cart is still saved and nothing has been charged.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/cart" class="btn btn-primary">Return to cart</a>
      <a href="/shop" class="btn btn-ghost">Keep browsing</a>
    </div>
  </div>
</main>
<Footer />
</Base>
